Package: SelvarMixMNAR
Type: Package
Title: Variable Selection in Model-Based Clustering with Missing not at
        Random Data
Version: 0.1.0.9000
Date: 2026-07-15
Authors@R: c(
    person("Mohammed", "Sedki", role = c("aut", "cre"),
           email = "mohammed.sedki@u-psud.fr",
           comment = "Original SelvarMix 1.2.1 author and legacy maintainer"),
    person("Gilles", "Celeux", role = "aut",
